generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// This is the blueprint. It doesn't change when you run a workflow, it's just the saved structure.
model WorkflowDefinition {
  id          String   @id @default(cuid())
  name        String
  description String?
  definition  Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  runs WorkflowRun[]

  @@map("workflow_definitions")
}

// This is a live execution of a workflow definition. Every time you hit "Run" on a workflow, a new WorkflowRun row is created. The definition stays untouched, the run is what changes over time.
model WorkflowRun {
  id          String    @id @default(cuid())
  workflowId  String
  status      RunStatus @default(PENDING)
  input       Json
  output      Json?
  startedAt   DateTime  @default(now())
  completedAt DateTime?
  error       String?
  critical    Boolean   @default(true)

  workflow WorkflowDefinition @relation(fields: [workflowId], references: [id])
  tasks    Task[]

  @@map("workflow_runs")
}

// This is a single step in a workflow run. Every node in your workflow graph becomes a Task row when a run starts. If your workflow has 4 nodes, a run creates 4 task rows.
model Task {
  id          String     @id @default(cuid())
  runId       String
  name        String
  type        AgentType
  status      TaskStatus @default(PENDING)
  input       Json
  output      Json?
  error       String?
  attempts    Int        @default(0)
  maxAttempts Int        @default(3)
  dependsOn   Json       @default("[]")
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime   @default(now())

  run WorkflowRun @relation(fields: [runId], references: [id])

  @@map("tasks")
}

// This is the worker registry. Every agent process that starts up registers itself here so the system knows it exists and what it can do.
model Agent {
  id           String      @id @default(cuid())
  name         String
  type         AgentType
  status       AgentStatus @default(OFFLINE)
  lastSeenAt   DateTime?
  tasksHandled Int         @default(0)
  tasksFailed  Int         @default(0)
  createdAt    DateTime    @default(now())

  @@unique([name, type])
  @@map("agents")
}

enum RunStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

enum TaskStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

enum AgentStatus {
  ONLINE
  OFFLINE
  BUSY
}

enum AgentType {
  LLM_AGENT
  HTTP_AGENT
  TRANSFORM_AGENT
  EXTRACTION_AGENT
  NOTIFICATION_AGENT
  STORAGE_AGENT
}
